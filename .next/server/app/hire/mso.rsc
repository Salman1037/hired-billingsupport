$","p",null,{"children":["$","em",null,{"children":"What you actually need is throughput. Today. Not next quarter."}]}]]}],["$","div",null,{"className":"pain-ledger fade-in","children":[["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"01"}],["$","div",null,{"className":"ptitle","children":"Volume scaling faster than headcount."}],["$","div",null,{"className":"pdesc","children":"Every signed client adds queue depth your back office didn't budget for. Queue depth costs SLA performance."}]]}],["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"02"}],["$","div",null,{"className":"ptitle","children":"AHT is creeping up."}],["$","div",null,{"className":"pdesc","children":"When processors are stretched, accuracy drops. When accuracy drops, rework spikes. Rework destroys margin faster than anything else."}]]}],["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"03"}],["$","div",null,{"className":"ptitle","children":"Hiring cycles are 90-180 days."}],["$","div",null,{"className":"pdesc","children":"Recruit, screen, hire, train, ramp. Client launches don't wait that long. Neither does existing volume."}]]}],["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"04"}],["$","div",null,{"className":"ptitle","children":"Unit economics are compressing."}],["$","div",null,{"className":"pdesc","children":"Operational cost per claim goes up. Reimbursement per claim goes down. Margin is the meat in the middle — getting thin."}]]}],["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"05"}],["$","div",null,{"className":"ptitle","children":"Standardization breaks at scale."}],["$","div",null,{"className":"pdesc","children":"What worked at 2,000 claims/week stops working at 8,000. SOPs drift. Quality varies. Reporting gaps appear."}]]}],["$","div",null,{"className":"pain-row","children":[["$","div",null,{"className":"pn","children":"06"}],["$","div",null,{"className":"ptitle","children":"Your best people are doing the wrong work."}],["$","div",null,{"className":"pdesc","children":"Senior staff fill in on routine processing because junior processors aren't keeping up. Judgment work goes unattended."}]]}]]}]]}]}],["$","section",null,{"className":"block warm","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"What's actually happening behind the scenes"}],["$","h2",null,{"className":"display","children":["You don't have a hiring problem. ",["$","em",null,{"children":"You have a capacity elasticity problem."}]]}]]}],["$","div",null,{"className":"monologue fade-in","style":{"maxWidth":820},"children":[["$","p",null,{"style":{"fontFamily":"var(--sans)","fontSize":17,"lineHeight":"1.65","color":"var(--ink-mute)"},"children":"Traditional operations scale the way furniture is built — slow, fixed, expensive. You commit to headcount, real estate, training infrastructure, and management overhead, and you bear the cost whether volume is at peak or trough."}],["$","p",null,{"style":{"fontFamily":"var(--sans)","fontSize":17,"lineHeight":"1.65","color":"var(--ink-mute)"},"children":"But healthcare volume isn't smooth. It spikes on new client launches. It surges at the start of every benefit year. It dips, then bursts. Your fixed cost structure can't move with it."}]]}],["$","div",null,{"className":"insight fade-in","style":{"marginTop":40},"children":["What you actually need is operations that flex — capacity that comes online in days, scales up or down without termination cost, and slots into your existing systems. ",["$","em",null,{"children":"That's not BPO. That's an operational layer."}]]}]]}]}],["$","section",null,{"className":"block","id":"solution","children":["$","div",null,{"className":"container","children