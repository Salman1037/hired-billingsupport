div","02",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"We work directly inside your EHR and PM system"}],["$","p",null,{"children":"We log in to your system. We work your queues. We post payments in your PM. No file exports, no third-party portals — just your existing environment with our team inside it."}]]}]]}],["$","div","03",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"We follow your SOPs — and improve them over time"}],["$","p",null,{"children":"We adapt to your existing workflows. Where we find gaps, we flag them, document the fix, and help formalize a stronger process so your billing operation becomes more consistent month over month."}]]}]]}]]}],["$","div",null,{"className":"process-list","children":[["$","div","04",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"04"}],["$","div",null,{"children":[["$","h4",null,{"children":"We communicate inside your team's channels daily"}],["$","p",null,{"children":"Slack, Teams, EHR messaging, email — wherever your team communicates, we show up there. Your staff communicates with a teammate, not a vendor with a ticket system."}]]}]]}],["$","div","05",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"05"}],["$","div",null,{"children":[["$","h4",null,{"children":"We scale without a new hiring cycle"}],["$","p",null,{"children":"New providers, new locations, seasonal volume — we scale immediately. No four-week job posting, no benefits overhead, no onboarding gaps that cost practices revenue while they wait."}]]}]]}],["$","div","06",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"06"}],["$","div",null,{"children":[["$","h4",null,{"children":"We report, review, and improve on a regular schedule"}],["$","p",null,{"children":"Performance reviews, denial trends, AR aging reports — delivered to your leadership on schedule. Not reactive reports after something goes wrong. Proactive visibility before problems compound."}]]}]]}]]}]]}]]}]}],["$","section",null,{"className":"block","id":"services","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"Complete RCM services"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"Every step of the revenue cycle. <em>Managed, not just monitored.</em>"}}],["$","p",null,{"children":"We do not specialize in one piece of the billing puzzle. We own the full workflow so nothing falls in the gap between departments, systems, or responsibilities."}]]}],["$","div",null,{"className":"services-grid fade-in","children":[["$","div","01",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"01"}],["$","h4",null,{"children":"Eligibility & Benefits Verification"}],["$","p",null,{"children":"Confirmed before every visit. Active coverage, deductibles, copays, and network status — verified against the actual payer, not a record from months ago."}]]}],["$","div","02",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"02"}],["$","h4",null,{"children":"Prior Authorization Support"}],["$","p",null,{"children":"We track, request, follow up on, and document every authorization so a missing auth is never the reason a claim is denied."}]]}],["$","div","03",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"03"}],["$","h4",null,{"children":"Charge Entry & Capture"}],["$","p",null,{"children":"Accurate, same-day or next-day charge entry with attention to modifiers, units, and diagnosis linkage. No delays, no shortcuts."}]]}],["$","div","04",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"04"}],["$","h4",null,{"children":"Claim Scrubbing & Review"}],["$","p",null,{"children":"Every claim reviewed for errors, payer-specific rules, and missing data before submission — not after the denial arrives."}]]}],["$","div","05",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"05"}],["$","h4",null,{"children":"Electronic Claims Submission"}],["$","p",null,{"children":"Formatted correctly for each payer, submitted promptly, and tracked from the moment it goes out to adjudication."}]]}],["$","div","06",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"06"}],["$","h4",null,{"children":"Denial Management"}],["$","p",null,{"children":"Every denial reviewed, categorized, and worked within a defined window. No denial sits idle while the timely filing clock runs down."}]]}],["$","div","07",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"07"}],["$","h4",null,{"children":"Appeals & Reconsiderations"}],["$","p",null,{"children":"When a denial is wrong, we build and submit the appeal — with clinical support, documentation, and payer-specific language that gives it the best chance of reversal."}]]}],["$","div","08",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"08"}],["$","h4",null,{"children":"AR Follow-Up"}],["$","p",null,{"children":"Aging buckets assigned and worked daily. Not just the easy claims — 90-day and 120-day accounts get the same attention as new submissions."}]]}],["$","div","09",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"09"}],["$","h4",null,{"children":"Payment Posting"}],["$","p",null,{"children":"ERA and manual EOB posting reconciled to the correct encounter with accuracy verification and adjustment review every time."}]]}],["$","div","10",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"10"}],["$","h4",null,{"children":"Underpayment Identification"}],["$","p",null,{"children":"Every payment checked against contracted rates. When a payer underpays, we identify it, document it, and pursue the balance."}]]}],["$","div","11",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"11"}],["$","h4",null,{"children":"Patient Balance Support"}],["$","p",null,{"children":"Patient responsibility balances reviewed and statements coordinated — so your front desk is not fielding billing calls all day."}]]}],["$","div","12",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"12"}],["$","h4",null,{"children":"Payer Communication"}],["$","p",null,{"children":"We call payers. We escalate. We document every interaction. Your team should not be spending its day on hold with insurance companies."}]]}],["$","div","13",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"13"}],["$","h4",null,{"children":"Reporting & Performance Tracking"}],["$","p",null,{"children":"Regular reports on collection rates, denial trends, AR aging, and clean claim rates — with commentary and context, not just raw numbers."}]]}],["$","div","14",{"className":"service-item","children":[["$","span",null,{"className":"service-num","children":"14"}],["$","h4",null,{"children":"Revenue Leakage Analysis"}],["$","p",null,{"children":"A structured review of where your revenue is being lost — missed charges, expired authorizations, unworked claims, underpayments, and write-off patterns."}]]}]]}]]}]}],"$undefined","$undefined",["$","section",null,{"className":"block block--warm","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"How we work"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"Not a service you send work to. <em>A team already inside your operation.</em>"}}],["$","p",null,{"children":"The reason most billing relationships fail is not the billing itself — it is the gap between what a vendor does and how a practice actually operates. We close that gap from day one."}]]}],["$","div",null,{"className":"process-list fade-in","style":{"maxWidth":780},"children":[["$","div","01",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"01"}],["$","div",null,{"children":[["$","h4",null,{"children":"Operational review before anything else"}],["$","p",null,{"children":"We spend time understanding how your practice bills today — your systems, your team structure, your payer mix, and your current revenue gaps. We are diagnosing your operation, not onboarding into a standard template."}]]}]]}],["$","div","02",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"We log in to your EHR — not our own system"}],["$","p",null,{"children":"Your EHR, your PM, your clearinghouse. We work the same queues your in-house team works, with the same access, the same visibility, and the same tools. No data exports, no workarounds."}]]}]]}],["$","div","03",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"We adapt to your payer mix and existing rules"}],["$","p",null,{"children":"Different payers. Different fee schedules. Different authorization requirements. We learn your specific payer environment and apply the right rules for each one — so your claims go out correctly the first time."}]]}]]}],["$","div","04",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"04"}],["$","div",null,{"children":[["$","h4",null,{"children":"We communicate where your team already communicates"}],["$","p",null,{"children":"Slack, email, EHR messaging — we are in the same channels as your staff. Your team does not file tickets or send emails to a billing vendor. They talk to a teammate who works remotely."}]]}]]}],["$","div","05",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"05"}],["$","div",null,{"children":[["$","h4",null,{"children":"Regular reporting — proactive, not reactive"}],["$","p",null,{"children":"Monthly performance reviews with denial trends, AR aging movement, clean claim rates, and collection analysis — delivered on schedule with commentary. Not a dashboard that sits unread. A conversation about what the numbers mean."}]]}]]}]]}]]}]}],["$","section",null,{"className":"block","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"The AI + human advantage"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"Technology handles what should never require a human. <em>Humans handle what technology cannot.</em>"}}],["$","p",null,{"children":"AI does not replace billing judgment. It makes billing specialists measurably more effective by handling every repetitive task that should never have required a person in the first place."}]]}],["$","div",null,{"className":"ai-split fade-in","children":[["$","div",null,{"className":"ai-col ai-col--machine","children":[["$","div",null,{"className":"ai-col-label","children":"AI-assisted RCM workflows"}],["$","div",null,{"className":"ai-items","children":[["$","div","0",{"className":"ai-item","children":[["$","div",null,{"className":"ai-item-dot"}],["$","p",null,{"children":"Eligibility verification queue management and real-time status tracking"}]]}],["$","div","1",{"className":"ai-item","children":[["$","div",null,{"className":"ai-item-dot"}],["$","p",null,{"