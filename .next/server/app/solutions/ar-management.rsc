d:[["$","section",null,{"className":"hero","children":[["$","div",null,{"className":"hero-bg","children":[["$","svg",null,{"viewBox":"0 0 1440 900","preserveAspectRatio":"xMidYMid slice","xmlns":"http://www.w3.org/2000/svg","children":[["$","defs",null,{"children":["$","pattern",null,{"id":"grid","width":"48","height":"48","patternUnits":"userSpaceOnUse","children":["$","path",null,{"d":"M 48 0 L 0 0 0 48","fill":"none","stroke":"#0A1628","strokeWidth":"0.5","opacity":"0.08"}]}]}],["$","rect",null,{"width":"100%","height":"100%","fill":"url(#grid)"}]]}],["$","div",null,{"className":"hero-grain"}]]}],["$","div",null,{"className":"hero-inner","children":[["$","div",null,{"children":[["$","div",null,{"className":"eyebrow reveal reveal-1","children":"AR Management"}],["$","h1",null,{"className":"display reveal reveal-2","style":{"fontSize":"clamp(38px, 5vw, 64px)","marginTop":"20px"},"dangerouslySetInnerHTML":{"__html":"The money is in your AR.<em>The problem is nobody has time to go get it.</em>"}}],["$","p",null,{"className":"sub reveal reveal-3","style":{"fontSize":"18px","lineHeight":"1.6","color":"var(--ink-mute)","marginTop":"24px"},"children":"Unpaid claims do not resolve themselves. Without systematic follow-up at every aging bucket, payers deprioritize your accounts — and cash flow tightens while your team manages everything else."}],["$","p",null,{"className":"lede reveal reveal-3","style":{"fontSize":"18px","lineHeight":"1.6","color":"var(--ink-mute)","marginTop":"16px"},"children":"HBS works your AR daily, follows up with every payer, and keeps collections moving on a schedule that does not depend on your team having extra hours."}],["$","div",null,{"className":"hero-actions reveal reveal-4","children":[["$","a",null,{"href":"/contact","className":"btn btn-primary btn-lg","children":["Contact us",["$","svg",null,{"className":"arrow","width":"14","height":"14","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","children":["$","path"