","children":["$","span",null,{"style":{"width":"6%"}}]}],["$","span",null,{"className":"ar-val","children":"4 Patterns"}]]}],["$","div",null,{"className":"gap-callout","style":{"marginTop":"20px"},"children":[["$","div",null,{"className":"gc-lbl","children":"— Action taken"}],["$","div",null,{"className":"gc-val","children":"All findings corrected. Two workflow changes recommended."}]]}],["$","div",null,{"style":{"marginTop":"14px","display":"flex","gap":"8px","flexWrap":"wrap"},"children":[["$","span",null,{"className":"card-tag before","children":"$$22K FOUND"}],["$","span",null,{"className":"card-tag after","children":"3 ROOT CAUSES"}],["$","span",null,{"className":"card-tag after","children":"100% DOCUMENTED"}]]}]]}]}]]}]]}],["$","section",null,{"className":"block","id":"pain","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"What is actually happening in your billing"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"Most revenue leakage is invisible <em>until someone is specifically looking for it.</em>"}}]]}],["$","div",null,{"className":"monologue fade-in","children":[["$","p","0",{"className":"","children":"Your billing team submits claims. Payers adjudicate them. Payments come in. Reports show collection rates. Everything looks manageable — until someone runs a detailed audit and finds that 12 percent of claims reviewed had avoidable coding errors, $18,000 in underpayments were accepted without review, and three providers had a documentation pattern that creates compliance risk."}],["$","p","1",{"className":"","children":"None of that showed up in a report. None of it was visible from the dashboard. It was only visible when someone had uninterrupted time to look through the actual claims, compare codes to documentation, check payments against contracts, and trace denial patterns back to their source."}],["$","p","2",{"className":"highlight","children":"\"Your team is not missing things because they are not paying attention. They are missing things because looking closely takes time — and time is the one resource nobody in a busy billing operation has enough of.\""}],["$","p","3",{"className":"","children":"A proactive audit is not about finding fault. It is about finding what nobody had time to find, documenting what needs to change, and giving your leadership the information they need to make those changes before payers or external auditors do it for them."}]]}]]}]}],["$","section",null,{"className":"block block--warm","id":"pain-details","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"Where the problem lives"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"The specific gaps <em>beneath the surface.</em>"}}]]}],["$","div",null,{"className":"pain-ledger fade-in","children":[["$","div","01",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"01"}],["$","div",null,{"children":[["$","h4",null,{"children":"Revenue leakage the practice does not know about"}],["$","p",null,{"children":"Undercoding, missed charges, documentation gaps that prevent full reimbursement, and underpayments accepted without review — these are not visible in summary reports. They are only visible in detailed claim-level analysis."}]]}]]}],["$","div","02",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"Coding errors repeating without being caught"}],["$","p",null,{"children":"When the same coder makes the same mistake across 30 claims per month, that error compounds silently until someone reviews the pattern. Without an audit function, there is no systematic review that catches patterns before they accumulate into significant loss."}]]}]]}],["$","div","03",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"Documentation that would not survive an external audit"}],["$","p",null,{"children":"The documentation in your charts does not need to be wrong to create audit risk. It needs to be incomplete, inconsistent, or misaligned with the billed code. Providers do not always know where those gaps are — and billing teams do not always have time to find them."}]]}]]}],["$","div","04",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"04"}],["$","div",null,{"children":[["$","h4",null,{"children":"Underpayments accepted as final without review"}],["$","p",null,{"children":"Payers routinely pay less than contracted rates — on individual claims, on specific procedure codes, or systematically across a payer relationship. Without someone comparing payments to contracts, those underpayments become permanent write-offs."}]]}]]}],["$","div","05",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"05"}],["$","div",null,{"children":[["$","h4",null,{"children":"Denial patterns without root cause analysis"}],["$","p",null,{"children":"Reports show denial rates. They rarely show why denial rates are what they are, which providers or code types are driving them, and what upstream workflow change would reduce them. Audits do."}]]}]]}],["$","div","06",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"06"}],["$","div",null,{"children":[["$","h4",null,{"children":"Payer audit risk building without visibility"}],["$","p",null,{"children":"If your practice were selected for a payer audit tomorrow, would you be confident in your documentation, your coding accuracy, and your billing compliance? Most practices are not sure — because nobody has looked at it recently from the auditor's perspective."}]]}]]}]]}]]}]}],"$undefined",["$","section",null,{"className":"block block--ink","id":"solution","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"The solution"}],["$","h2",null,{"className":"display display--light","dangerouslySetInnerHTML":{"__html":"We look at your billing the way an auditor would <em>— before they do.</em>"}}],["$","p",null,{"children":"Hired Billing Support conducts structured medical billing and coding audits — identifying revenue leakage, documentation risk, coding errors, and compliance exposure — and delivering findings your leadership team can actually act on."}]]}],["$","div",null,{"className":"two-col fade-in","children":[["$","div",null,{"className":"process-list","children":[["$","div","01",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"01"}],["$","div",null,{"children":[["$","h4",null,{"children":"Scope definition and audit planning"}],["$","p",null,{"children":"We work with your leadership to define the audit scope — which providers, which code types, which payers, which time period. Every audit is planned to answer specific questions about your billing performance."}]]}]]}],["$","div","02",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"Claim-level review against documentation"}],["$","p",null,{"children":"We pull claims and compare billed codes, modifiers, and diagnosis linkage against clinical documentation. We are looking for what the payer would see — not just what your team submitted."}]]}]]}],["$","div","03",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"Payment accuracy review"}],["$","p",null,{"children":"Payments received c