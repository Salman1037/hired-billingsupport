width":"0%"}}]}],["$","span",null,{"className":"ar-val","children":"0"}]]}],["$","div",null,{"className":"gap-callout","style":{"marginTop":"20px"},"children":[["$","div",null,{"className":"gc-lbl","children":"— This month's priority"}],["$","div",null,{"className":"gc-val","children":"Denial rate above target — root cause in progress."}]]}],["$","div",null,{"style":{"marginTop":"14px","display":"flex","gap":"8px","flexWrap":"wrap"},"children":[["$","span",null,{"className":"card-tag before","children":"MONTHLY"}],["$","span",null,{"className":"card-tag after","children":"REPORT CADENCE"}],["$","span",null,{"className":"card-tag after","children":"6 KPIs TRACKED"}],["$","span",null,{"className":"card-tag after","children":"LEADERSHIP READY"}]]}]]}]}]]}]]}],["$","section",null,{"className":"block","id":"pain","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"The visibility problem in healthcare operations"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"Leadership is making decisions with <em>incomplete information</em> about their own revenue cycle."}}]]}],["$","div",null,{"className":"monologue fade-in","children":[["$","p","0",{"className":"","children":"The billing team is working. Claims are going out. Payments are coming in. And at the leadership level, the most current view of the revenue cycle is a monthly summary report — numbers without context, trends without explanation, and issues without root causes."}],["$","p","1",{"className":"","children":"Leadership knows the collection rate. They do not know which payer is driving 40 percent of denials, why AR over 90 days grew last quarter, whether coding accuracy improved after the last feedback session, or whether the practice has any growing compliance exposure they should be aware of."}],["$","p","2",{"className":"highlight","children":"\"The practices that manage their revenue cycle well are not the ones with the most data. They are the ones who understand what their data is telling them — and who have someone translating the numbers into decisions.\""}],["$","p","3",{"className":"","children":"Compliance is the same. Billing compliance risk does not announce itself. It accumulates through coding patterns, documentation habits, and billing practices that nobody is systematically reviewing. By the time it surfaces — in a payer audit, a recoupment demand, or a corrective action plan — the damage is already done."}]]}]]}]}],["$","section",null,{"className":"block block--warm","id":"pain-details","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"Where the problem lives"}],["$","h2",null,{"className":"display","dangerouslySetInnerHTML":{"__html":"The specific gaps <em>beneath the surface.</em>"}}]]}],["$","div",null,{"className":"pain-ledger fade-in","children":[["$","div","01",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"01"}],["$","div",null,{"children":[["$","h4",null,{"children":"Reports show numbers — not what to do about them"}],["$","p",null,{"children":"A denial rate report that shows 4.2 percent does not tell you whether that is trending up, which payers are driving it, what coding issue is behind it, or what would bring it down. Numbers without context produce decisions without foundation."}]]}]]}],["$","div","02",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"Compliance issues are found too late to prevent damage"}],["$","p",null,{"children":"Billing compliance risk builds through patterns — coding habits, documentation practices, billing process gaps. Those patterns are only visible if someone is specifically monitoring for them. Without systematic compliance review, risk accumulates until it becomes a problem."}]]}]]}],["$","div","03",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"Different team members follow different processes"}],["$","p",null,{"children":"When there is no standardized process monitoring, different coders, billers, and AR specialists develop their own habits. Inconsistency is invisible until it creates an error, a denial pattern, or a compliance flag — and by then it has been happening for months."}]]}]]}],["$","div","04",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"04"}],["$","div",null,{"children":[["$","h4",null,{"children":"AR reports are reviewed too late to act on"}],["$","p",null,{"children":"When leadership sees an AR aging report showing 90-day balances growing, the optimal follow-up window on many of those claims has already started closing. Reporting cadence needs to match decision timelines, not administrative schedules."}]]}]]}],["$","div","05",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"05"}],["$","div",null,{"children":[["$","h4",null,{"children":"Denial trends are tracked but not analyzed"}],["$","p",null,{"children":"Denial rates appear in monthly reports. But without a breakdown by reason code, payer, provider, and trend direction — with root cause analysis and upstream recommendations — the denial rate is just a number that fluctuates without explanation."}]]}]]}],["$","div","06",{"className":"pain-item","children":[["$","div",null,{"className":"pain-num","children":"06"}],["$","div",null,{"children":[["$","h4",null,{"children":"No one owns follow-up on reported findings"}],["$","p",null,{"children":"A report identifies an issue. Someone acknowledges it. Nothing changes. Without a defined owner, a follow-up date, and a verification step, reported findings become recurring line items — not resolved problems."}]]}]]}]]}]]}]}],"$undefined",["$","section",null,{"className":"block block--ink","id":"solution","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"block-head fade-in","children":[["$","div",null,{"className":"eyebrow","children":"The solution"}],["$","h2",null,{"className":"display display--light","dangerouslySetInnerHTML":{"__html":"Reporting that gives leadership clarity. <em>Compliance monitoring that catches risk early.</em>"}}],["$","p",null,{"children":"Hired Billing Support builds and maintains structured reporting across your billing, coding, AR, and denial activity — and monitors for compliance risk so your leadership team always knows where performance stands and where attention is needed."}]]}],["$","div",null,{"className":"two-col fade-in","children":[["$","div",null,{"className":"process-list","children":[["$","div","01",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"01"}],["$","div",null,{"children":[["$","h4",null,{"children":"We define the KPIs that matter for your practice"}],["$","p",null,{"children":"Collection rate, denial rate, days in AR, clean claim rate, coding accuracy, AR aging distribution — we align the reporting framework to your practice size, payer mix, and leadership priorities."}]]}]]}],["$","div","02",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"02"}],["$","div",null,{"children":[["$","h4",null,{"children":"We build reports your leadership can actually read"}],["$","p",null,{"children":"Not data exports with hundreds of rows. Structured reports with context, trend lines, and plain-language commentary explaining what the numbers mean and what actions they suggest."}]]}]]}],["$","div","03",{"className":"process-item","children":[["$","div",null,{"className":"process-num","children":"03"}],["$","div",null,{"children":[["$","h4",null,{"children":"We monitor 