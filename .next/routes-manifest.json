{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/rcm-management",
      "destination": "/solutions/rcm-management",
      "statusCode": 308,
      "regex": "^(?!/_next)/rcm-management(?:/)?$"
    },
    {
      "source": "/start-ups",
      "destination": "/who-we-serve/start-ups",
      "statusCode": 308,
      "regex": "^(?!/_next)/start-ups(?:/)?$"
    },
    {
      "source": "/medical-billing-rcm",
      "destination": "/solutions/medical-billing-rcm",
      "statusCode": 308,
      "regex": "^(?!/_next)/medical-billing-rcm(?:/)?$"
    },
    {
      "source": "/ar-management",
      "destination": "/solutions/ar-management",
      "statusCode": 308,
      "regex": "^(?!/_next)/ar-management(?:/)?$"
    },
    {
      "source": "/provider-credential",
      "destination": "/solutions/provider-credential",
      "statusCode": 308,
      "regex": "^(?!/_next)/provider-credential(?:/)?$"
    },
    {
      "source": "/payer-insurer-enrollment",
      "destination": "/solutions/payer-insurer-enrollment",
      "statusCode": 308,
      "regex": "^(?!/_next)/payer-insurer-enrollment(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    },
    {
      "source": "/(api|_next|private|tmp)/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ],
      "regex": "^(?:/(api|_next|private|tmp))(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/case-study/[slug]",
      "regex": "^/case\\-study/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/case\\-study/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/hire/[slug]",
